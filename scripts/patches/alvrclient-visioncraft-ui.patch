+
+private struct VisionCraftSetupPanel: View {
+    @ObservedObject var eventHandler: EventHandler
+
+    var body: some View {
+        VStack(alignment: .leading, spacing: 10) {
+            HStack {
+                Label("VisionCraft Setup", systemImage: "visionpro")
+                    .font(.headline)
+                Spacer()
+                Text(eventHandler.connectionState == .connected ? "Connected" : "Waiting for Mac")
+                    .font(.caption.bold())
+                    .padding(.horizontal, 10)
+                    .padding(.vertical, 5)
+                    .background((eventHandler.connectionState == .connected ? Color.green : Color.orange).opacity(0.18), in: Capsule())
+            }
+
+            VStack(alignment: .leading, spacing: 6) {
+                setupLine("1", "Run `scripts/vc.sh host --rebuild` on the Mac.")
+                setupLine("2", "Keep the Mac and Apple Vision Pro awake on the same LAN.")
+                setupLine("3", "When connected, press Enter, then start `scripts/vc.sh sender` or Minecraft + F7.")
+            }
+
+            if !eventHandler.hostAlvrVersion.isEmpty {
+                Text("Host ALVR: \(eventHandler.hostAlvrVersion)")
+                    .font(.caption)
+                    .foregroundStyle(.secondary)
+            } else if eventHandler.connectionState != .connected {
+                Text("If this stays here, run `scripts/vc.sh doctor` on the Mac and confirm ALVR artifacts, signing, and firewall/network state.")
+                    .font(.caption)
+                    .foregroundStyle(.secondary)
+            }
+        }
+        .padding()
+        .frame(maxWidth: .infinity, alignment: .leading)
+        .background(.regularMaterial, in: RoundedRectangle(cornerRadius: 18))
+        .padding(.horizontal)
+    }
+
+    private func setupLine(_ number: String, _ text: String) -> some View {
+        HStack(alignment: .firstTextBaseline, spacing: 8) {
+            Text(number)
+                .font(.caption.bold())
+                .frame(width: 22, height: 22)
+                .background(.thinMaterial, in: Circle())
+            Text(text)
+                .font(.caption)
+                .textSelection(.enabled)
+        }
+    }
+}
