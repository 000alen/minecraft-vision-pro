{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",

  "name": "${mod_name}",
  "description": "${description}",
  "icon": "vivecraft_icon.png",
  "authors": [
    "${mod_authors_array}"
  ],

  "license": "${license}",

  "environment": "*",
  "entrypoints": {
    "mm:early_risers": [
      "org.vivecraft.fabric.VivecraftEarlyEntryForOptifabric"
    ],
    "main": [
      "org.vivecraft.fabric.VivecraftMod"
    ],
    "modmenu": [
      "org.vivecraft.fabric.client.VivecraftModMenuApiImpl"
    ]
  },
  "mixins": [
    "vivecraft.mixins.json",
    "vivecraft.fabric.mixins.json",
    "vivecraft.accessories.mixins.json",
    "vivecraft.alexmobs.mixins.json",
    "vivecraft.bedrockify.mixins.json",
    "vivecraft.blur.mixins.json",
    "vivecraft.cataclysm.mixins.json",
    "vivecraft.dynamicfps.mixins.json",
    "vivecraft.elementa.mixins.json",
    "vivecraft.emf.mixins.json",
    "vivecraft.epicfight.mixins.json",
    "vivecraft.iris.mixins.json",
    "vivecraft.mca.mixins.json",
    "vivecraft.modmenu.mixins.json",
    "vivecraft.optifine.mixins.json",
    "vivecraft.rei.mixins.json",
    "vivecraft.resolutioncontrol.mixins.json",
    "vivecraft.sereneseasons.mixins.json",
    "vivecraft.sodium.mixins.json",
    "vivecraft.voxy.mixins.json",
    "vivecraft.xaerosmimimap.mixins.json",
    "vivecraft.xaerosworldmap.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.1",
    "minecraft": ${fabric_mc_range},
    "java": ">=${java_version}"
  },
  "breaks": {
    "sodium": ["0.4.11+build.25", "0.4.11+build.26"]
  },
  "contact": {
    "homepage": "${website}",
    "issues": "${issue_tracker}",
    "sources": "${sources}"
  },
  "custom": {
    "mc-publish": {
      "dependencies": [
        "sodium(incompatible)#(ignore)"
      ]
    },
    "modmenu": {
      "links": {
        "modmenu.discord": "${discord}",
        "vivecraft.message.kofi": "${kofi}"
      },
      "update_checker": true
    }
  },
  "accessWidener": "vivecraft.accesswidener"
}
