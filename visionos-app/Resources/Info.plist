<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ARKit on-device tracking. Hand tracking is the whole point of the companion; world
	     sensing backs the device (head) anchor. Both are gated by these usage strings. -->
	<key>NSHandsTrackingUsageDescription</key>
	<string>VisionCraft uses hand tracking so pinching your fingers mines and places blocks.</string>
	<key>NSWorldSensingUsageDescription</key>
	<string>VisionCraft uses head and world tracking to render the game from your point of view.</string>

	<!-- LAN discovery of the Mac relay over Bonjour (bridge/stream-protocol.md). Required for
	     NWBrowser to find, and NWConnection to reach, the host on the local network. -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>VisionCraft connects to the VisionCraft host running on your Mac over your local network.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_visioncraft-stream._tcp</string>
	</array>

	<!-- Foveated Streaming is intentionally NOT enabled: it requires NVIDIA CloudXR on the host
	     side, which is incompatible with the Mac-only (Apple Silicon) architecture. -->
</dict>
</plist>
